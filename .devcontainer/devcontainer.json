{
  "name": "Middleman Preview",

  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },

  "forwardPorts": [4567],

  "postStartCommand": "bundle exec middleman server -p 4567 -h 0.0.0.0 --incremental",

  "portsAttributes": {
    "4567": {
      "label": "Middleman Preview",
      "onAutoForward": "openBrowser"
    }
  }
}